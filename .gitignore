# Variables de entorno — NUNCA al repositorio (contienen credenciales)
.env

# Entorno virtual — no se commitea, cada dev crea el suyo
venv/
env/

# Python compilado
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Base de datos local SQLite (usamos PostgreSQL en Docker)
db.sqlite3

# Archivos de media (uploads de usuarios)
# Se gestionan por separado en produccion (S3, etc.)
media/

# Archivos estaticos colectados (se generan con collectstatic)
staticfiles/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.swp

# Logs
*.log
